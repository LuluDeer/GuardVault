generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Department {
  id        Int              @id @default(autoincrement())
  name      String           @unique @db.VarChar(64)
  code      String           @unique @db.VarChar(32)
  remark    String?          @db.VarChar(256)
  status    Int              @default(1)
  sort      Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  services  ServiceAccount[]
  users     SystemUser[]

  @@map("department")
}

model SystemUser {
  id                 Int                 @id @default(autoincrement())
  username           String              @unique @db.VarChar(32)
  password           String              @db.VarChar(128)
  role               String              @db.VarChar(16)
  status             Int                 @default(1)
  failCount          Int                 @default(0) @map("fail_count")
  lockedUntil        DateTime?           @map("locked_until")
  lastLoginTime      DateTime?           @map("last_login_time")
  lastLoginIp        String?             @map("last_login_ip") @db.VarChar(45)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deptId             Int?                @map("dept_id")
  favorites          AccountFavorite[]
  grantedByMe        AccountGrant[]      @relation("GrantOperator")
  grants             AccountGrant[]      @relation("GrantUser")
  passwordResetToken PasswordResetToken?
  refreshTokens      RefreshToken[]
  createdServices    ServiceAccount[]    @relation("ServiceCreator")
  department         Department?         @relation(fields: [deptId], references: [id])
  totpChallenge      TotpChallenge?
  totpKey            UserTotpKey?        @relation("UserTotpKey")

  @@index([deptId])
  @@index([role])
  @@index([status])
  @@index([username])
  @@map("system_user")
}

model UserTotpKey {
  id              Int        @id @default(autoincrement())
  userId          Int        @unique @map("user_id")
  encryptedSecret String     @map("encrypted_secret") @db.VarChar(512)
  isEnable        Int        @default(0) @map("is_enable")
  resetCount      Int        @default(0) @map("reset_count")
  resetTime       DateTime?  @map("reset_time")
  createdAt       DateTime   @default(now()) @map("created_at")
  user            SystemUser @relation("UserTotpKey", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_totp_key")
}

model ServiceAccount {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(64)
  category        String            @db.VarChar(32)
  identifier      String?           @db.VarChar(128)
  url             String?           @db.VarChar(256)
  remark          String?           @db.VarChar(256)
  icon            String?           @db.VarChar(512)
  encryptedSecret String            @map("encrypted_secret") @db.VarChar(512)
  digits          Int               @default(6)
  period          Int               @default(30)
  algorithm       String            @default("SHA1")
  status          Int               @default(1)
  deptId          Int               @map("dept_id")
  createdById     Int               @map("created_by_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  favorites       AccountFavorite[]
  grants          AccountGrant[]
  createdBy       SystemUser        @relation("ServiceCreator", fields: [createdById], references: [id])
  department      Department        @relation(fields: [deptId], references: [id])

  @@index([deptId])
  @@index([category])
  @@index([status])
  @@index([createdById], map: "service_account_created_by_id_fkey")
  @@map("service_account")
}

model AccountGrant {
  id          Int            @id @default(autoincrement())
  userId      Int            @map("user_id")
  accountId   Int            @map("account_id")
  grantedById Int            @map("granted_by_id")
  grantedAt   DateTime       @default(now()) @map("granted_at")
  remark      String?        @db.VarChar(256)
  account     ServiceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  grantedBy   SystemUser     @relation("GrantOperator", fields: [grantedById], references: [id])
  user        SystemUser     @relation("GrantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId])
  @@index([userId])
  @@index([accountId])
  @@index([grantedById], map: "account_grant_granted_by_id_fkey")
  @@map("account_grant")
}

model AccountFavorite {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  accountId Int            @map("account_id")
  sort      Int            @default(0) @map("sort_order")
  pinnedAt  DateTime       @default(now()) @map("pinned_at")
  account   ServiceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      SystemUser     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId])
  @@index([userId, sort])
  @@index([accountId], map: "account_favorite_account_id_fkey")
  @@map("account_favorite")
}

model SystemLog {
  id                BigInt   @id @default(autoincrement())
  operatorId        Int      @map("operator_id")
  operatorName      String   @map("operator_name") @db.VarChar(32)
  targetUserId      Int?     @map("target_user_id")
  targetUsername    String?  @map("target_username") @db.VarChar(32)
  targetAccountId   Int?     @map("target_account_id")
  targetAccountName String?  @map("target_account_name") @db.VarChar(64)
  actionType        String   @map("action_type") @db.VarChar(32)
  actionDesc        String   @map("action_desc") @db.VarChar(512)
  clientIp          String   @map("client_ip") @db.VarChar(45)
  userAgent         String?  @map("user_agent") @db.VarChar(256)
  result            Int
  failReason        String?  @map("fail_reason") @db.VarChar(256)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([operatorId])
  @@index([actionType])
  @@index([targetAccountId])
  @@index([createdAt, operatorId])
  @@map("system_log")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique @map("config_key") @db.VarChar(64)
  configValue String   @map("config_value") @db.VarChar(256)
  description String?  @db.VarChar(256)
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by") @db.VarChar(32)

  @@map("system_config")
}

model TokenBlacklist {
  jti       String   @id @db.VarChar(64)
  expireAt  BigInt   @map("expire_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expireAt])
  @@map("token_blacklist")
}

model IpBlock {
  id        Int      @id @default(autoincrement())
  ip        String   @unique @db.VarChar(45)
  reason    String   @db.VarChar(256)
  expireAt  BigInt   @map("expire_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([expireAt])
  @@map("ip_block")
}

model LoginAttempt {
  id            Int      @id @default(autoincrement())
  ip            String   @db.VarChar(45)
  username      String   @db.VarChar(32)
  resource      String   @db.VarChar(32)
  attemptNumber Int      @map("attempt_number")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([ip])
  @@index([createdAt])
  @@map("login_attempt")
}

model RefreshToken {
  id        Int        @id @default(autoincrement())
  token     String     @unique @db.VarChar(128)
  userId    Int        @map("user_id")
  expireAt  DateTime   @map("expire_at")
  createdAt DateTime   @default(now()) @map("created_at")
  user      SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expireAt])
  @@map("refresh_token")
}

model TotpChallenge {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique @map("user_id")
  username  String     @db.VarChar(32)
  token     String     @db.VarChar(64)
  expireAt  DateTime   @map("expire_at")
  attempts  Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  user      SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expireAt])
  @@map("totp_challenge")
}

model PasswordResetToken {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique @map("user_id")
  username  String     @db.VarChar(32)
  token     String     @unique @db.VarChar(64)
  expireAt  DateTime   @map("expire_at")
  attempts  Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  user      SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expireAt])
  @@map("password_reset_token")
}
