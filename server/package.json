{
  "name": "totp-server",
  "version": "1.0.0",
  "description": "局域网TOTP验证码服务端",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "e2e": "node ../scripts/e2e-test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@fastify/compress": "^6.5.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "8.15.0",
    "@fastify/swagger-ui": "4.1.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^12.0.1",
    "zod": "^3.25.76"
  }
}
